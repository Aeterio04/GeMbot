# Copy this to .env and fill in your values
# NEVER commit .env to git

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Your ngrok HTTPS tunnel URL (regenerate each session)
EXPO_PUBLIC_API_URL=https://xxxx-xx-xx-xxx-xx.ngrok-free.app

# RevenueCat public SDK key (safe to expose)
EXPO_PUBLIC_REVENUECAT_KEY=appl_xxxxxxxxxxxxxxxxxxxx
